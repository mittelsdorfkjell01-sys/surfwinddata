# Python
__pycache__/
*.py[cod]
.venv/
*.egg-info/
.pytest_cache/

# Env — never commit real secrets. Only the *.example templates are tracked.
.env
.env.*
!.env.example
# (env.prod.example has no leading dot, so it is not matched above and stays tracked.)

# Backups (pg_dump / media tarballs written on the host)
/backups/

# ERA5 raw extracts (downloaded data, not source)
/data/era5_raw/

# OS
.DS_Store
Thumbs.db

# Local screenshots / runtime media (not source)
screens/
/data/media/
