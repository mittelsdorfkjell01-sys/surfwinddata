# Single-domain deploy: the SPA is served at / and the API + uploaded media under
# /api — frontend and backend share ONE origin (${DOMAIN}). That keeps the admin
# login session cookie first-party/same-site (plain SameSite=Lax; no CORS needed).
#
# ${DOMAIN} is read from .env.prod. Caddy provisions a Let's Encrypt certificate
# automatically ON THE FIRST REQUEST — this REQUIRES a DNS A-record for ${DOMAIN}
# pointing at the VPS public IP to exist *before* the first request, and ports
# 80 + 443 reachable from the internet. Without the A-record, certificate
# issuance fails and Caddy serves nothing.
{$DOMAIN} {
	encode zstd gzip

	# API + uploaded media -> backend. handle_path strips the /api prefix, so the
	# app still sees its normal routes (/spots, /auth/login, /admin/*, /media/*).
	handle_path /api/* {
		reverse_proxy app:8000
	}

	# Everything else is the static single-page app (client-side routing: unknown
	# paths fall back to index.html).
	handle {
		root * /srv/www
		try_files {path} /index.html
		file_server
	}
}
