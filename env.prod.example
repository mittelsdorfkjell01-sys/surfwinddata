# Copy to .env.prod on the VPS and fill in. NEVER commit .env.prod (it is
# gitignored). Generate the two secrets with:
#
#   POSTGRES_PASSWORD:  openssl rand -base64 32
#   ADMIN_KEY:          openssl rand -base64 48
#
# Run compose with:  docker compose --env-file .env.prod -f docker-compose.prod.yml up -d --build

# --- domain / TLS ----------------------------------------------------------
# The ONE domain that serves everything: the SPA at / and the API under /api
# (see Caddyfile). A DNS A-record for this MUST point at the VPS IP before first
# start, or Caddy's automatic certificate fails. The frontend is built with
# VITE_API_URL=/api (baked in via frontend/Dockerfile) — no separate frontend host.
DOMAIN=kjellmittelsdorf.de

# --- database (Postgres + PostGIS) -----------------------------------------
POSTGRES_USER=surf
POSTGRES_PASSWORD=change-me-openssl-rand-base64-32
POSTGRES_DB=surfwind
# DATABASE_URL is assembled from the three values above in docker-compose.prod.yml
# (host = the "db" service). Do not set it here.

# --- redis (cache) ---------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# --- app -------------------------------------------------------------------
# Single-domain deploy = frontend and API share one origin, so the browser makes
# only SAME-ORIGIN calls and CORS is never triggered. Set to the domain anyway
# (harmless belt-and-suspenders; needed only if you ever split the frontend off).
CORS_ORIGINS=https://kjellmittelsdorf.de
# Uploaded hero images live here (backed by the persistent "media" volume).
MEDIA_DIR=/app/data/media
MEDIA_URL_PREFIX=/media
# Turn off interactive docs/verbose errors in production.
API_DEBUG=false

# --- admin auth (Sprint A) -------------------------------------------------
# Secret signing the admin session JWT. REQUIRED in prod. Generate with:
#   openssl rand -base64 48
JWT_SECRET=change-me-openssl-rand-base64-48
# First-run bootstrap: on startup, if there are no admin users yet, one admin is
# created from these two. Set them for the first deploy, then you may unset the
# password. Never reuse a weak value.
ADMIN_BOOTSTRAP_EMAIL=you@example.com
ADMIN_BOOTSTRAP_PASSWORD=change-me-strong-first-password
# Send the session cookie only over HTTPS (leave true in prod behind TLS).
COOKIE_SECURE=true
# Contact address surfaced by the take-down / image-report flow (Sprint C).
TAKEDOWN_CONTACT_EMAIL=abuse@example.com
# OPTIONAL emergency break-glass: when set, a correct X-Admin-Key header is
# accepted as an admin (actor "break-glass"). Leave UNSET for normal operation.
#   openssl rand -base64 48
# ADMIN_KEY=change-me-openssl-rand-base64-48
