# Copy to .env and adjust as needed.

# Main application database (Postgres + PostGIS)
DATABASE_URL=postgresql+psycopg://surf:surf@localhost:5432/surfwind

# Database used by the test-suite. Created/dropped automatically by pytest.
TEST_DATABASE_URL=postgresql+psycopg://surf:surf@localhost:5432/surfwind_test

# Redis (not used for logic yet in Sprint 1, only wired up for later sprints)
REDIS_URL=redis://localhost:6379/0

# FastAPI
API_TITLE=Surfwinddate API
API_DEBUG=true

# Browser origins allowed to call the API (CORS). Comma-separated or a JSON array.
# The Vite dev server runs on 5173.
CORS_ORIGINS=http://localhost:5173

# Uploaded hero images: where they are stored on disk and the URL prefix they are
# served from (StaticFiles mount). Stored image URLs are root-relative.
MEDIA_DIR=data/media
MEDIA_URL_PREFIX=/media

# Directory for downloaded raw climatology extracts (Parquet), incl. the
# Open-Meteo fetch cache under <dir>/omcache/.
ERA5_RAW_DIR=data/era5_raw

# Rolling window (weeks) to smooth the 52-week climatology curve (wrap-around).
# 1 disables smoothing, 3 = ±1 week.
CLIMATOLOGY_SMOOTH_WEEKS=3

# TTL (seconds) for cached Open-Meteo live/forecast responses (30-60 min).
LIVE_CACHE_TTL=1800

# Optional comma-separated override of the independent global models whose
# disagreement forms the forecast consensus band (Sprint 18). Unset => the
# built-in trio (icon_seamless, gfs_seamless, ecmwf_ifs025).
# LIVE_CONSENSUS_MODELS=icon_seamless,gfs_seamless,ecmwf_ifs025

# --- admin auth (Sprint A) -------------------------------------------------
# Secret signing the admin session JWT. The dev default in app/config.py keeps
# local runs working; override it anywhere real.
# JWT_SECRET=dev-insecure-change-me
# Session lifetime (hours) and cookie flags. COOKIE_SECURE must be false over
# plain http (dev), true behind HTTPS (prod).
# JWT_TTL_HOURS=12
# COOKIE_SECURE=false
# First-run bootstrap admin (created on startup if no admin users exist).
# ADMIN_BOOTSTRAP_EMAIL=admin@localhost
# ADMIN_BOOTSTRAP_PASSWORD=change-me
# Contact address for the take-down / image-report flow (Sprint C).
# TAKEDOWN_CONTACT_EMAIL=abuse@localhost

# Optional emergency break-glass key (X-Admin-Key header → admin). Unset by
# default; the regular path is the cookie session above.
# ADMIN_KEY=change-me

# Stock-image lookups for region images (Sprint 8 admin). Optional.
# UNSPLASH_ACCESS_KEY=...
